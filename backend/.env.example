# Backend Environment Variables

# MongoDB Connection String
# Local: mongodb://localhost:27017/SmartCampus
# MongoDB Atlas: mongodb+srv://username:password@cluster.xxxxx.mongodb.net/SmartCampus?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/SmartCampus

# Server Port (Railway will set this automatically)
PORT=8080

# Frontend URL for CORS
# Local: http://localhost:5173
# Vercel: https://your-app.vercel.app
FRONTEND_URL=http://localhost:5173

# JWT Secret (change this in production)
JWT_SECRET=9a4f2c8d3b7a1e6f45c8a0b3f267d8b1d4e6f3c8a9d2b5f8e3a9c8b5f6v8a3d9
